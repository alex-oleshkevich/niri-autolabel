[Unit]
Description=niri-autolabel — niri workspace content labeler
Documentation=https://github.com/alex-oleshkevich/niri-autolabel
# niri exposes itself to the user session as graphical-session.target.
After=graphical-session.target
PartOf=graphical-session.target
Requisite=graphical-session.target

[Service]
Type=simple
# OPENROUTER_API_KEY is required. Provide it via a drop-in
# (`systemctl --user edit niri-autolabel`), an imported user-manager
# environment, or one of these optional env files:
EnvironmentFile=-%h/.config/niri-autolabel/env
EnvironmentFile=-%h/.config/autolabel/env
ExecStart=/usr/bin/niri-autolabel
Restart=on-failure
RestartSec=2
# SIGINT/SIGTERM make niri-autolabel clear the labels it set before exiting.
KillSignal=SIGTERM
TimeoutStopSec=10

[Install]
WantedBy=graphical-session.target
